# ── SOP Creator environment ──────────────────────────────────────────────
# SETUP:
#   1. Copy this file to ".env"   (Windows: copy .env.example .env)
#   2. Replace the two placeholder values below with your own.
#   3. Run "az login" so the app can authenticate (no API key needed).
# Your real .env is gitignored — never commit it.

# Your Azure AI Foundry PROJECT endpoint.
# Find it at https://ai.azure.com -> your project -> Overview -> "Endpoint".
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_AIPROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# The model DEPLOYMENT name from your Foundry project (Deployments tab),
# e.g. gpt-4.1-mini or gpt-4o.
AI_MODEL=gpt-4.1-mini

# development or production
APP_ENV=development
